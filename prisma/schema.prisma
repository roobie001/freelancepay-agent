// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  address     String   @unique
  name        String?
  email       String?
  role        String   // "client" or "freelancer"
  agentId     Int?
  agentUri    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  postedJobs    Job[]     @relation("PostedJobs")
  assignedJobs  Job[]     @relation("AssignedFreelancer")
  applications  Application[]
  disputes      Dispute[]
  evidence      Evidence[]
  clientAgreements Agreement[] @relation("ClientAgreements")
  freelancerAgreements Agreement[] @relation("FreelancerAgreements")
  submissions  Submission[]
  notifications Notification[]

  @@map("users")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  budget      Float
  status      String   @default("open") // "open", "in_progress", "completed", "disputed"
  blockchainId Int?    // ID on the blockchain
  clientId    String
  client      User     @relation("PostedJobs", fields: [clientId], references: [id])
  freelancerId String?
  freelancer  User?    @relation("AssignedFreelancer", fields: [freelancerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  applications Application[]
  disputes     Dispute[]
  milestones   Milestone[]
  agreement    Agreement?
  submissions  Submission[]
  timelineEvents TimelineEvent[]

  @@map("jobs")
}

model Milestone {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  index     Int
  amount    Float
  status    String   @default("pending") // "pending", "submitted", "approved", "paid", "disputed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, index])
  @@map("milestones")
}

model Submission {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer  User     @relation(fields: [freelancerId], references: [id])
  uri         String
  description String?
  createdAt   DateTime @default(now())

  @@map("submissions")
}

model Application {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer   User     @relation(fields: [freelancerId], references: [id])
  proposal     String
  proposedRate Float?
  coverLetter  String?
  timelineDays Int?
  bidAmount    Float?
  deliverables String?
  milestones   Json?
  portfolioLink String?
  agreedToTerms Boolean @default(false)
  applicationHash String?
  chainTxHash   String?
  metadataUri   String?
  status       String   @default("pending") // "pending", "accepted", "rejected"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agreement    Agreement?

  @@unique([jobId, freelancerId])
  @@map("applications")
}

model Dispute {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  agreementId String?
  agreement   Agreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  initiatedBy String
  initiator   User     @relation(fields: [initiatedBy], references: [id])
  reason      String
  reasonType  String   @default("other") // "scope_not_met" | "late_delivery" | "poor_quality" | "payment_refusal" | "other"
  reasonDetails String?
  aiDecision  String?  // AI agent's decision
  resolved    Boolean  @default(false)
  status      String   @default("open") // "open", "resolved", "appealed"
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evidence    Evidence[]
  appeals     Appeal[]
  decisions   Decision[]
  timelineEvents TimelineEvent[]

  @@map("disputes")
}

model Agreement {
  id             String   @id @default(cuid())
  jobId          String   @unique
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicationId  String   @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  clientId       String
  client         User     @relation("ClientAgreements", fields: [clientId], references: [id])
  freelancerId   String
  freelancer     User     @relation("FreelancerAgreements", fields: [freelancerId], references: [id])
  agreedAmount   Float
  milestones     Json?
  deliverables   String?
  deadlineDays   Int?
  status         String   @default("active") // "active", "completed", "disputed", "terminated"
  contractJson   Json
  createdAt      DateTime @default(now())
  disputes       Dispute[]
  timelineEvents TimelineEvent[]

  @@map("agreements")
}

model Evidence {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  appealId   String?
  appeal     Appeal?  @relation(fields: [appealId], references: [id], onDelete: Cascade)
  submittedBy String
  submitter  User     @relation(fields: [submittedBy], references: [id])
  role       String   // "client" or "freelancer"
  type       String   // "screenshot" | "figma" | "live_url" | "chat_proof" | "github_repo" | "other"
  uri        String
  description String?
  isAppeal   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("evidence")
}

model Appeal {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  reason     String
  status     String   @default("pending") // "pending", "approved", "rejected"
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  evidence   Evidence[]
  decisions  Decision[]

  @@map("appeals")
}

model Decision {
  id           String   @id @default(cuid())
  disputeId    String
  dispute      Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  appealId     String?
  appeal       Appeal?  @relation(fields: [appealId], references: [id], onDelete: SetNull)
  decision     String   // "client" | "freelancer" | "partial"
  confidence   Float
  reasoning    String
  paymentSplit Json
  txHash       String?
  executedOnChain Boolean @default(false)
  isAppeal     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@map("decisions")
}

model TimelineEvent {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  agreementId String?
  agreement   Agreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  disputeId   String?
  dispute     Dispute? @relation(fields: [disputeId], references: [id], onDelete: SetNull)
  type        String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("timeline_events")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
